{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "boatmaster",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','css':'text/css','js':'text/javascript','json':'application/json','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml','mp3':'audio/mpeg'};h.createServer((q,r)=>{let u=q.url.split('?')[0];u=u==='/'?'/index.html':u;let fp=p.join('/Users/angelojuric/Documents/Bootsführerschein/app',u);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}let ext=p.extname(fp).slice(1);r.writeHead(200,{'Content-Type':m[ext]||'text/plain','Content-Length':d.length});r.end(d)})}).listen(8080,()=>console.log('Serving on 8080'))"],
      "port": 8080
    }
  ]
}
